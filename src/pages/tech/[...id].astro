---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('tech', ({ data }) => !data.draft);
  return posts.map(post => ({ params: { id: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const base = import.meta.env.BASE_URL;

function formatDate(d: Date) {
  return d.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
}
---
<Base title={post.data.title} description={post.data.description}>
  <article>
    <header class="article-header">
      <div class="breadcrumb">
        <a href={`${base}tech`}>技术</a>
        <span>/</span>
      </div>
      <h1 class="article-title">{post.data.title}</h1>
      <div class="article-meta">
        <time>{formatDate(post.data.date)}</time>
        {post.data.tags.map(t => (
          <span class="tag-sm">{t}</span>
        ))}
      </div>
      {post.data.description && (
        <p class="article-desc">{post.data.description}</p>
      )}
    </header>

    <div class="prose">
      <Content />
    </div>
  </article>
</Base>

<style>
  article {
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .article-header {
    padding: 3rem 0 2.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 2.5rem;
  }

  .breadcrumb {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--text-faint);
    display: flex;
    gap: 0.4rem;
    align-items: center;
    margin-bottom: 1.2rem;
  }

  .breadcrumb a {
    color: var(--text-muted);
    transition: color 0.2s;
  }
  .breadcrumb a:hover { color: var(--accent); }

  .article-title {
    font-size: clamp(1.4rem, 4vw, 1.9rem);
    font-weight: 400;
    line-height: 1.4;
    letter-spacing: 0.02em;
    margin-bottom: 1rem;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--text-faint);
  }

  .tag-sm {
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 0.1em 0.4em;
    border-radius: 2px;
    font-size: 0.68rem;
    color: var(--text-muted);
  }

  .article-desc {
    margin-top: 1rem;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.7;
    font-style: italic;
  }
</style>
